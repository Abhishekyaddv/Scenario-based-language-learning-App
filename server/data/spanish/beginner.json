        "learningMaterial": {
          "title": "Numbers & Colors",
          "intro": "Master counting from 1 to 10 and identifying basic colors to describe the world around you.",
          "concepts": [
            {
              "term": "Uno, dos, tres, cuatro, cinco",
              "explanation": "The numbers 1 through 5."
