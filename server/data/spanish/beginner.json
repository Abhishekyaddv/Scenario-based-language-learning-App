        "id": "beginner_ch1",
        "title": "Greetings & Introductions",
        "description": "Learn basic hellos, goodbyes, and how to introduce yourself.",
        "lessons": [
          {
            "id": "b_ch1_l1",
            "type": "vocabulary",
            "prompt": "What does 'Hola' mean?",
            "options": [
              "Hello",
              "Goodbye",
              "Thank you",
              "Please"
            ],
            "correctAnswer": "Hello",
            "explanation": "'Hola' is the most common informal greeting."
          },
          {
            "id": "b_ch1_l2",
            "type": "translate",
            "prompt": "Translate: 'My name is Rahul'",
            "correctAnswer": "Me llamo Rahul",
            "hint": "Use 'Me llamo' + your name."
          },
          {
            "id": "b_ch1_l3",
            "type": "fill_blank",
            "prompt": "Buenos ___, ¿cómo estás?",
            "correctAnswer": "días",
            "explanation": "'Buenos días' means Good morning."
          },
          {
            "id": "b_ch1_l4",
            "type": "translate",
            "prompt": "Translate: 'See you later'",
            "correctAnswer": "Hasta luego",
            "hint": "Think of 'Until later'."
          }
        ],
        "learningMaterial": {
          "title": "Greetings & Introductions",
          "intro": "Before we begin the exercises, let's review the most common ways to greet people in Spanish.",
          "concepts": [
            {
              "term": "Hola",
              "explanation": "The most common and versatile way to say Hello in Spanish."
            },
            {
              "term": "Buenos días",
              "explanation": "Good morning (used until noon)."
            },
            {
              "term": "Me llamo...",
              "explanation": "My name is... (Literally: I call myself...)"
            },
            {
              "term": "Hasta luego",
              "explanation": "See you later / Until later."
            }
          ]
        }
      },
      {
