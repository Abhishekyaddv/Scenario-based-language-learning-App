        "learningMaterial": {
          "title": "Weather & Seasons",
          "intro": "Description of the climate typically requires the verb \"hacer\" instead of \"ser\". Let's see how it works.",
          "concepts": [
            {
              "term": "Hace frío",
              "explanation": "It is cold. (Literally: It makes cold)."
