        ],
        "learningMaterial": {
          "title": "Family & Friends",
          "intro": "Learn how to refer to the important people in your life using simple Spanish nouns.",
          "concepts": [
            {
              "term": "Hermano / Hermana",
              "explanation": "Brother / Sister. The \"H\" is silent in Spanish."
            },
            {
              "term": "Madre / Padre",
              "explanation": "Mother / Father. Use \"Ella es mi madre\" to say \"She is my mother\"."
            },
            {
              "term": "Amigo / Amiga",
              "explanation": "Friend (male / female)."
            },
            {
              "term": "Abuelo / Abuela",
              "explanation": "Grandfather / Grandmother."
            }
          ]
        }
