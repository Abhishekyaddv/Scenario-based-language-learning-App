        "description": "Talk about rooms in the house and domestic tasks.",
        "lessons": [
          {
            "id": "i_ch5_l1",
            "type": "vocabulary",
            "prompt": "What is 'El dormitorio'?",
            "options": ["Kitchen", "Living Room", "Bathroom", "Bedroom"],
            "correctAnswer": "Bedroom",
            "explanation": "It is the room where you sleep ('dormir')."
          },
          {
            "id": "i_ch5_l2",
            "type": "translate",
            "prompt": "Translate: 'I have to clean the kitchen'",
            "correctAnswer": "Tengo que limpiar la cocina",
