{
  "level": "intermediate",
  "chapters": [
      {
        "id": "intermediate_ch1",
        "title": "Daily Routines",
        "description": "Describe your day using reflexive verbs.",
        "lessons": [
          {
            "id": "i_ch1_l1",
            "type": "vocabulary",
            "prompt": "What does 'Despertarse' mean?",
            "options": ["To go to sleep", "To wake up", "To eat breakfast", "To shower"],
            "correctAnswer": "To wake up",
            "explanation": "It's a reflexive verb used when you wake yourself up."
          },
          {
            "id": "i_ch1_l2",
            "type": "fill_blank",
            "prompt": "Yo ___ lavo los dientes todos los días.",
            "correctAnswer": "me",
            "explanation": "Use the reflexive pronoun 'me' for 'yo'."
          },
          {
            "id": "i_ch1_l3",
            "type": "translate",
            "prompt": "Translate: 'We get up early'",
            "correctAnswer": "Nos levantamos temprano",
            "hint": "Use the 'nosotros' reflexive pronoun."
          }
        ]
      },
      {
        "id": "intermediate_ch2",
        "title": "Past Vacations",
        "description": "Talk about where you went and what you did using the Preterite tense.",
        "lessons": [
          {
            "id": "i_ch2_l1",
            "type": "fill_blank",
            "prompt": "El año pasado, yo ___ a España.",
            "correctAnswer": "fui",
            "explanation": "'Fui' is the preterite 'I went' (from the verb 'ir')."
          },
          {
            "id": "i_ch2_l2",
            "type": "vocabulary",
            "prompt": "How do you say 'We ate' in the past tense?",
            "options": ["Comemos", "Comíamos", "Comimos", "Comeremos"],
            "correctAnswer": "Comimos",
            "explanation": "'Comimos' is the preterite form for nosotros."
          },
          {
            "id": "i_ch2_l3",
            "type": "translate",
            "prompt": "Translate: 'I visited the museum'",
            "correctAnswer": "Visité el museo",
            "hint": "Use the 'yo' form of 'visitar' in the preterite."
          }
        ]
      },
      {
        "id": "intermediate_ch3",
        "title": "Childhood Memories",
        "description": "Describe what things used to be like using the Imperfect tense.",
        "lessons": [
          {
            "id": "i_ch3_l1",
            "type": "vocabulary",
            "prompt": "Which verb tense is used for habitual actions in the past?",
            "options": ["Preterite", "Imperfect", "Future", "Conditional"],
            "correctAnswer": "Imperfect",
            "explanation": "The imperfect is used for 'used to' or 'was doing'."
          },
          {
            "id": "i_ch3_l2",
            "type": "fill_blank",
            "prompt": "Cuando era niño, ___ al parque todos los días.",
            "correctAnswer": "iba",
            "explanation": "'Iba' is the imperfect of 'ir' (I used to go)."
          },
          {
            "id": "i_ch3_l3",
            "type": "translate",
            "prompt": "Translate: 'We used to play soccer'",
            "correctAnswer": "Jugábamos al fútbol",
            "hint": "Remember the accent mark on the first 'a' in jugábamos."
          }
        ]
      },
      {
        "id": "intermediate_ch4",
        "title": "Health & Body",
        "description": "Describe symptoms and body parts at the doctor.",
        "lessons": [
          {
            "id": "i_ch4_l1",
            "type": "vocabulary",
            "prompt": "What does 'Me duele la cabeza' mean?",
            "options": ["My back hurts", "I have a headache", "My stomach hurts", "I am tired"],
            "correctAnswer": "I have a headache",
            "explanation": "'Cabeza' means head."
          },
          {
            "id": "i_ch4_l2",
            "type": "fill_blank",
            "prompt": "El médico me recetó unas ___.",
            "correctAnswer": "pastillas",
            "explanation": "'Pastillas' means pills/medicine."
          },
          {
            "id": "i_ch4_l3",
            "type": "translate",
            "prompt": "Translate: 'I feel sick'",
            "correctAnswer": "Me siento enfermo",
            "hint": "Use the reflexive verb 'sentirse'."
          }
        ]
      },
      {
        "id": "intermediate_ch5",
