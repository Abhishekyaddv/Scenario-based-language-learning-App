            "explanation": "'Contraseña' means password."
          },
          {
            "id": "i_ch6_l3",
            "type": "translate",
            "prompt": "Translate: 'Send me a message'",
            "correctAnswer": "Envíame un mensaje",
            "hint": "Use the command form of 'enviar' with the pronoun 'me'."
          }
        ]
      },
      {
