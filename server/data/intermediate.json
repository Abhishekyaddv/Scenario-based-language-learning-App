          },
          {
            "id": "i_ch5_l3",
            "type": "fill_blank",
            "prompt": "Por favor, saca la ___.",
            "correctAnswer": "basura",
            "explanation": "'Sacar la basura' means to take out the trash."
          }
        ]
      },
      {
